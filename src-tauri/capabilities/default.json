{
  "identifier": "default",
  "description": "Default window capabilities including save file access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "shell:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPLOCALDATA/**" }]
    }
  ]
}
