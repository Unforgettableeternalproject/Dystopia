{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dystopia",
  "version": "0.1.0",
  "identifier": "com.uep.dystopia",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://0.0.0.0:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Dystopia",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
