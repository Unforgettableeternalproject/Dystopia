{
  "id": "crambell_enc_kach_briefing",
  "name": "凱奇的委託",
  "type": "event",
  "description": "凱奇把玩家叫到一旁，說明他接下來幾天需要玩家的幫助。",
  "entryNodeId": "kach_approach",
  "nodes": {
    "kach_approach": {
      "id": "kach_approach",
      "dmNarrative": "凱奇假裝在整理工具，把玩家叫過來。聲音壓得很低：「明天我需要你幫個忙。我有些事要辦，辦完之前不能被人注意到我不在工作區。」他頓了頓，「你幫我頂著，把今天的量做到兩份。如果有人問起，就說我在裡頭搬貨。」",
      "choices": [
        {
          "id": "accept",
          "text": "「好，我幫你。」",
          "nextNodeId": "kach_grateful"
        },
        {
          "id": "ask_why",
          "text": "「你去辦什麼？」",
          "nextNodeId": "kach_evasive"
        },
        {
          "id": "decline",
          "text": "「這不是我的事，我不想卷進去。」",
          "nextNodeId": "kach_accepted_no"
        }
      ]
    },
    "kach_evasive": {
      "id": "kach_evasive",
      "dmNarrative": "凱奇看了玩家一眼，「說了你也不會懂。」他停頓一下，「但這很重要。如果成功的話，對你也有好處。」",
      "choices": [
        {
          "id": "accept_anyway",
          "text": "「好吧。我幫你。」",
          "nextNodeId": "kach_grateful"
        },
        {
          "id": "still_decline",
          "text": "「不，謝了。」",
          "nextNodeId": "kach_accepted_no"
        }
      ]
    },
    "kach_grateful": {
      "id": "kach_grateful",
      "dmNarrative": "凱奇點了點頭，語氣比平常稍微輕鬆一點。「謝謝你。記住，如果有人問，我在裡面搬貨。」他回到自己的位置，開始工作，好像什麼都沒說過。",
      "isOutcome": true,
      "outcomeType": "success",
      "effects": {
        "grantQuestId": "crambell_kach_test1",
        "flagsSet": ["crambell_kach_test1_invited", "crambell_kach_test1_started"]
      }
    },
    "kach_accepted_no": {
      "id": "kach_accepted_no",
      "dmNarrative": "凱奇沉默了片刻。「沒事。」他轉回去繼續手上的工作，語氣沒什麼起伏，好像早有心理準備。",
      "isOutcome": true,
      "outcomeType": "neutral",
      "effects": {
        "flagsSet": ["crambell_kach_test1_invited"]
      }
    }
  }
}
