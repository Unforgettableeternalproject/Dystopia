      ]
    },
    {
      "nodeId": "night_chat",
      "condition": "crambell_mildore_talked_once & !crambell_task_shackles_started",
      "timeRanges": [
        { "startHour": 22, "startMinute": 0, "endHour": 5, "endMinute": 59 }
      ]
    }
  ],

  "contextSnippets": [
    {
      "label": "米爾多雷被捕",
      "condition": "crambell_mildore_arrested",
      "context": "米爾多雷被捕後心情沉穩，她對自己的行為沒有後悔，但對連累玩家的可能感到不安，說話時語氣比平常更直接，少了玩笑。"
    },
    {
      "label": "玩家協助救出米爾多雷",
      "condition": "crambell_mildore_rescued",
      "context": "被救後米爾多雷對玩家有深厚的感激，同時帶著一絲不自在——她不擅長接受直接的幫助，可能用輕鬆的語氣掩蓋情緒。"
    }
  ]
}
