      }
    },
    {
      "id": "trigger_encounter",
      "description": "調轉契機終於浮現，玩家可進入相應遭遇。",
      "flagsSet": ["crambell_transfer_trigger_checked"],
      "weight": 2,
      "eventCounterReset": ["crambell_transfer_trigger_progress"],
      "startEncounterId": "crambell_enc_transfer_trigger"
