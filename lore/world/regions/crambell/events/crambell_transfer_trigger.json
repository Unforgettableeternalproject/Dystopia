{
  "id": "crambell_transfer_trigger",
  "name": "轉移機會",
  "_comment": [
    "轉移觸發事件（單次版本）。",
    "使用 outcome.weightByEventCounter 搭配 crambell_transfer_trigger_progress 調整各結果的抽選權重。",
    "計數器 0/1/2/3+ 分別對應 25% / 50% / 75% / 100% 的觸發機率。",
    "crambell_transfer_trigger_checked 僅阻止同一天內重複判定。"
  ],
  "locationId": "delth_mining_shafts",
  "condition": {
    "timePeriods": ["work"],
    "flags": ["crambell_quota_met_today"],
    "notFlags": [
      "crambell_transfer_trigger_checked",
      "crambell_transfer_opportunity:active",
      "crambell_transfer_permit_collected"
    ]
  },
  "description": "玩家在礦場完成當日配額後，可能出現轉移機會。若未出現，機率將在之後的日子累積提升。",
  "outcomes": [
    {
      "id": "no_opportunity_today",
      "description": "今日未出現任何轉移線索，但下次觸發的機率將提高。",
      "flagsSet": ["crambell_transfer_trigger_checked"],
      "weightByEventCounter": {
        "counterId": "crambell_transfer_trigger_progress",
        "valueWeights": {
          "0": 3,
          "1": 2,
          "2": 1,
          "3": 0
        },
        "fallback": "nearest_lower"
      },
      "eventCounterChanges": {
        "crambell_transfer_trigger_progress": 1
      }
    },
    {
      "id": "trigger_encounter",
      "description": "工作途中出現轉移線索，玩家進入觸發遭遇。",
      "flagsSet": ["crambell_transfer_trigger_checked"],
      "weightByEventCounter": {
        "counterId": "crambell_transfer_trigger_progress",
        "valueWeights": {
          "0": 1,
          "1": 2,
          "2": 3,
          "3": 1
        },
        "fallback": "nearest_lower"
      },
      "eventCounterReset": ["crambell_transfer_trigger_progress"],
      "startEncounterId": "crambell_enc_transfer_trigger"
    }
  ],
  "isRepeatable": true,
  "notification": true
}
