{
  "_schema": "GameEvent — one file per event",
  "id": "region_event_name",
  "locationId": "optional_location_id (省略 = 全域事件，由 RegionIndex.globalEventIds 掛載)",

  "_comment_condition": [
    "flags:          這些旗標全部存在才觸發",
    "anyFlags:       至少一個旗標存在才觸發",
    "notFlags:       這些旗標全部不存在才觸發（適合自我標記設計）",
    "minStats:       玩家數值門檻，如 { 'statusStats.stamina': 3 }",
    "timePeriod:     限定時段觸發，如 ['work']、['work','rest']",
    "cooldownMinutes:可重複事件的冷卻（遊戲內分鐘），0 或省略 = 不限次數",
    "",
    "自我標記設計（period transition 慣用）：",
    "  condition.notFlags: ['event_fired_flag']",
    "  outcome.flagsSet:   ['event_fired_flag']",
    "  -> 同一時段只觸發一次，下一次條件重設時再觸發"
  ],

  "condition": {
    "flags": ["required_flag"],
    "anyFlags": ["any_of_these"],
    "notFlags": ["must_be_absent"],
    "minStats": { "statusStats.stamina": 3 },
    "timePeriod": ["work", "rest", "special"],
    "cooldownMinutes": 120
  },

  "description": "DM-facing 事件描述。向 DM 說明此刻世界發生了什麼，DM 自行決定如何融入敘事。",
  "outcomes": [
    {
      "id": "outcome_1",
      "condition": "flag_expression (省略 = 無條件選用)",
      "description": "DM-facing 結果描述。",
      "flagsSet": ["event_outcome_1_done"],
      "flagsUnset": ["event_precondition_flag"],
      "statChanges": {
        "statusStats.stress": 2,
        "statusStats.stamina": -1
      }
    }
  ],
  "isRepeatable": false
}
