# 複製此檔案為 .env 並填入你的設定
# Copy this file to .env and fill in your settings

# --- 優先順序：Anthropic > Ollama > HuggingFace > mock ---

# Anthropic API (雲端，最高品質)
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Ollama 本地模型 (設定 model tag 即啟用，MVP 推薦)
VITE_OLLAMA_MODEL=gemma4:e4b-it-q4_K_M

# HuggingFace Serverless API (雲端，備用)
VITE_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
